--TEST--
Feature requiring the same package should have the locked version duplicated in each feature
--COMPOSER--
{
    "repositories": [
        {
            "type": "package",
            "package": [
                { "name": "a/a", "version": "1.0.0" },
                { "name": "b/b", "version": "1.0.0" },
                { "name": "c/c", "version": "1.0.0" }
            ]
        }
    ],
    "require": {
        "a/a": "1.0.0"
    },
    "features": {
        "b": {
            "description": "Feature B",
            "require": {
                "b/b": "1.0.0"
            }
        },
        "c": {
            "description": "Feature C",
            "require": {
                "b/b": "1.0.0",
                "c/c": "1.0.0"
            }
        }
    }
}
--LOCK--
{
    "packages": [
        {
            "name": "a/a", "version": "1.0.0",
            "type": "library"
        },
        {
            "name": "b/b", "version": "1.0.0",
            "type": "library"
        }
    ],
    "packages-dev": [],
    "aliases": [],
    "minimum-stability": "stable",
    "stability-flags": {},
    "prefer-stable": false,
    "prefer-lowest": false,
    "platform": {},
    "platform-dev": {},
    "self-features": ["b"]
}
--RUN--
install --self-feature c
--EXPECT-EXIT-CODE--
4

--EXPECT-OUTPUT--
Installing dependencies from lock file (including require-dev)
Error: The lock file is not up to date with required features: c. Please run composer update.

--EXPECT--
