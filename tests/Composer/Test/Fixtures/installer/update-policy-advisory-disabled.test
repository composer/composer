--TEST--
Security advisory policy disabled resulting in a successful update despite the advisory.
--COMPOSER--
{
    "name": "acme/project",
    "version": "1.0.0",
    "require": {
        "acme/library": "1.0.0"
    },
    "config": {
        "policy": {
            "advisories": false
        }
    },
    "repositories": [
        {
            "type": "package",
            "package": [
                {
                    "name": "acme/library",
                    "version": "1.0.0",
                    "source": { "reference": "some.branch", "type": "git", "url": "" }
                }
            ],
            "security-advisories": {
                "acme/library": [
                    {
                        "advisoryId": "PKSA-1234-abcd-1234",
                        "packageName": "acme/library",
                        "remoteId": "test",
                        "title": "Security Advisory",
                        "link": null,
                        "cve": null,
                        "affectedVersions": ">=1.0.0,<1.1.0",
                        "source": "Tests",
                        "reportedAt": "2024-04-31 12:37:47",
                        "composerRepository": "Package Repository",
                        "severity": "high",
                        "sources": [
                            {
                                "name": "Security Advisory",
                                "remoteId": "test"
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
--RUN--
update -v

--EXPECT-EXIT-CODE--
0

--EXPECT-OUTPUT--
Loading composer repositories with package information
Updating dependencies
Lock file operations: 1 install, 0 updates, 0 removals
  - Locking acme/library (1.0.0)
Writing lock file
Installing dependencies from lock file (including require-dev)
Package operations: 1 install, 0 updates, 0 removals
Generating autoload files
--EXPECT--
Installing acme/library (1.0.0)
